# Ohio Pride PAC — Next.js environment variables
# Copy to .env.local for development; set the same keys in the Vercel dashboard for deployment.

# Supabase (required for /api routes that read site data)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ActBlue donor sync (required for /api/actblue-sync cron job)
ACTBLUE_USERNAME=
ACTBLUE_PASSWORD=
ACTBLUE_ENTITY_ID=
ACTBLUE_REFCODE_PREFIX=ohpride
